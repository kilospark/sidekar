{
  "manifest_version": 3,
  "name": "Sidekar",
  "version": "0.7.3",
  "description": "Bridge between AI agents and your browser",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-light-16.png",
      "48": "icons/icon-light-48.png",
      "128": "icons/icon-light-128.png"
    },
    "theme_icons": [
      { "light": "icons/icon-dark-16.png", "dark": "icons/icon-light-16.png", "size": 16 },
      { "light": "icons/icon-dark-48.png", "dark": "icons/icon-light-48.png", "size": 48 },
      { "light": "icons/icon-dark-128.png", "dark": "icons/icon-light-128.png", "size": 128 }
    ]
  },
  "icons": {
    "16": "icons/icon-light-16.png",
    "48": "icons/icon-light-48.png",
    "128": "icons/icon-light-128.png"
  },
  "host_permissions": [
    "<all_urls>",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ]
}
