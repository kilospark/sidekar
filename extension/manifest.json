{
  "manifest_version": 3,
  "name": "Sidekar",
  "version": "1.0.17",
  "description": "Bridge between AI agents and your browser",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "clipboardWrite",
    "debugger",
    "alarms",
    "storage",
    "offscreen",
    "history"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-light-16.png",
      "48": "icons/icon-light-48.png",
      "128": "icons/icon-light-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-light-16.png",
    "48": "icons/icon-light-48.png",
    "128": "icons/icon-light-128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
